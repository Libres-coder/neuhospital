# Example / template for server/.env. DO NOT commit the real .env — only this
# template goes into git. Copy this file to `server/.env` and replace the
# placeholder values before starting the backend.
#
# Spring Boot reads these via HospitalApplication#loadDotenvIfPresent, which
# copies each entry into a JVM system property IF the same name isn't already
# set as an OS env var (production deploys override the .env).

# ────────────────────────────────────────────────────────────────────────
# Alibaba Bailian / DashScope — AI chat + vision calls (AiChatService).
#
# Two flavours, pick one:
#   1) Default DashScope (China):  key starts with `sk-` from
#      https://bailian.console.aliyun.com/  →  leave BASE_URL empty.
#   2) Dedicated MaaS workspace:    key + endpoint look like
#      https://<workspaceId>.cn-beijing.maas.aliyuncs.com/api/v1
#      →  set BASE_URL to that endpoint.
# ────────────────────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-REPLACE_ME
# DASHSCOPE_BASE_URL=https://your-workspace.cn-beijing.maas.aliyuncs.com/api/v1
DASHSCOPE_BASE_URL=
DASHSCOPE_MODEL_CHAT=qwen-turbo
DASHSCOPE_MODEL_VISION=qwen-vl-plus