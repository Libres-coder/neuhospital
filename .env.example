# Copy this file to `.env` next to docker-compose.yml and edit values as needed.
# Everything left blank or absent falls back to the default shown after `:-`.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=neusoft_hospital
MYSQL_USER=hospital
MYSQL_PASSWORD=hospital_pass
# Host port that maps to container port 3306. Use 3307 if you already run
# a local MySQL on 3306.
MYSQL_HOST_PORT=3307

# --- Hospital backend ---
# Host port that maps to the container's 8090.
HOSPITAL_HOST_PORT=8090

# JWT signing secret. **MUST** be a long random string in production.
JWT_SECRET=neusoft-hospital-dev-secret-key-please-rotate-in-production

# Dev SMS verification code. Leave blank in production (real gateway).
SMS_FIXED_CODE=123456

# CORS — comma-separated origins, or `*` for any.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false